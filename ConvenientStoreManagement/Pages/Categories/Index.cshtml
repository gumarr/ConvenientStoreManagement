@page
@model ConvenientStoreManagement.Pages.Categories.IndexModel

@{
    ViewData["Title"] = "Categories";
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col-md-6">
            <h2>@ViewData["Title"]</h2>
        </div>
        <div class="col-md-6 text-end">
            <a asp-page="Create" class="btn btn-primary">+ New Category</a>
        </div>
    </div>

    @if (Model.Categories.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Category Name</th>
                        <th>Description</th>
                        <th>Status</th>
                        <th>Created Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var category in Model.Categories)
                    {
                        <tr>
                            <td>@category.CategoryName</td>
                            <td>@category.Description</td>
                            <td>
                                @if (category.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inactive</span>
                                }
                            </td>
                            <td>@category.CreatedDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <a asp-page="Edit" asp-route-id="@category.CategoryId" class="btn btn-sm btn-warning">Edit</a>
                                <a asp-page="Delete" asp-route-id="@category.CategoryId" class="btn btn-sm btn-danger">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">No categories found. <a asp-page="Create">Create one now</a></div>
    }
</div>
