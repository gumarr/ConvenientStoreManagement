@page "{id:int}"
@model ConvenientStoreManagement.Pages.Inventory.DetailsModel
@{
    ViewData["Title"] = $"Receipt #{Model.Receipt?.ReceiptId} Details";
}

<div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold">🔍 Import Receipt Details #@Model.Receipt?.ReceiptId</h2>
            <p class="text-muted mb-0">
                Staff: <strong>@(Model.Receipt?.User?.FullName ?? Model.Receipt?.User?.Username ?? $"User #{Model.Receipt?.UserId}")</strong>
                &nbsp;·&nbsp;
                Import Date: <strong>@Model.Receipt?.ImportDate.ToString("dd/MM/yyyy HH:mm")</strong>
            </p>
        </div>
        <a asp-page="/Inventory/History" class="btn btn-outline-secondary">
            ← Back to List
        </a>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        @if (!Model.Details.Any())
        {
            <div class="text-center py-5 text-muted">
                <p>This import receipt has no details.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Product Name</th>
                            <th class="text-center">Quantity</th>
                            <th class="text-end">Original Import Price</th>
                            <th class="text-end">Avg Import Price</th>
                            <th class="text-end">Line Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in Model.Details)
                        {
                            decimal lineTotal = d.Quantity * d.OriginalImportPrice;
                            <tr>
                                <td class="fw-semibold">@(d.Product?.Name ?? $"Product #{d.ProductId}")</td>
                                <td class="text-center">@d.Quantity</td>
                                <td class="text-end">@d.OriginalImportPrice.ToString("N0") VNĐ</td>
                                <td class="text-end text-primary">@d.ImportPrice.ToString("N0") VNĐ</td>
                                <td class="text-end fw-bold text-danger">@lineTotal.ToString("N0") VNĐ</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-secondary">
                        <tr>
                            <td colspan="4" class="text-end fw-bold">Total:</td>
                            <td class="text-end fw-bold text-danger fs-5">
                                @Model.Receipt?.TotalCost.ToString("N0") VNĐ
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
            <div class="mt-3">
                <p class="text-muted small">
                    <strong>Original Import Price</strong>: the actual price paid when importing this batch.<br />
                    <strong>Avg Import Price</strong>: the weighted average price after combining with previous stock.
                </p>
            </div>
        }
    </div>
</div>
