@page
@model ConvenientStoreManagement.Pages.Inventory.HistoryModel
@{
    ViewData["Title"] = "Inventory Import History";
}

<div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold">📜 Lịch sử nhập kho</h2>
            <p class="text-muted mb-0">Xem tất cả phiếu nhập kho đã được tạo trong hệ thống.</p>
        </div>
        <a asp-page="/Inventory/Import" class="btn btn-outline-primary">
            ➕ Tạo phiếu nhập mới
        </a>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        @if (!Model.Receipts.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-box-open fs-1 mb-3"></i>
                <p class="fs-5">Chưa có phiếu nhập nào.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover table-bordered align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Mã phiếu (Receipt ID)</th>
                            <th>Nhân viên (Staff)</th>
                            <th>Ngày nhập (Import Date)</th>
                            <th class="text-end">Tổng tiền (Total Cost)</th>
                            <th class="text-center">Chi tiết</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.Receipts)
                        {
                            <tr>
                                <td class="fw-semibold">#@r.ReceiptId</td>
                                <td>@(r.User?.FullName ?? r.User?.Username ?? $"User #{r.UserId}")</td>
                                <td>@r.ImportDate.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-end text-danger fw-bold">@r.TotalCost.ToString("N0") VNĐ</td>
                                <td class="text-center">
                                    <a asp-page="/Inventory/Details" asp-route-id="@r.ReceiptId"
                                       class="btn btn-sm btn-outline-info">
                                        🔍 Xem
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
