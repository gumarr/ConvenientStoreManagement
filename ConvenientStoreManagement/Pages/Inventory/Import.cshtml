@page
@model ConvenientStoreManagement.Pages.Inventory.ImportModel
@{
    ViewData["Title"] = "Import Inventory";
}

<div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold">📦 Import Inventory</h2>
            <p class="text-muted mb-0">Import existing products or add new ones. The system automatically calculates average prices and updates selling prices.</p>
        </div>
        <a asp-page="/Inventory/History" class="btn btn-outline-secondary">
            📜 Import History
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <strong>Success!</strong> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <form method="post" id="importForm" enctype="multipart/form-data">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle" id="itemsTable">
                    <thead class="table-light">
                        <tr>
                            <th style="min-width: 200px;">Product</th>
                            <th style="min-width: 150px;">New Product Name</th>
                            <th style="min-width: 150px;">Category</th>
                            <th style="min-width: 100px;">Unit</th>
                            <th style="min-width: 110px;">Quantity</th>
                            <th style="min-width: 140px;">Import Price</th>
                            <th style="min-width: 130px;" title="Selling Price = Avg Import Price × Multiplier">Multiplier <span class="text-muted small">(?)</span></th>
                            <th style="min-width: 160px;">Image</th>
                            <th style="width: 50px;"></th>
                        </tr>
                    </thead>
                    <tbody id="itemsBody">
                        @if (Model.ImportRequest.Items != null && Model.ImportRequest.Items.Count > 0)
                        {
                            for (int i = 0; i < Model.ImportRequest.Items.Count; i++)
                            {
                                var isExisting = Model.ImportRequest.Items[i].ProductId.HasValue;
                                <tr>
                                    <td>
                                        <select class="form-select product-select" asp-for="ImportRequest.Items[i].ProductId">
                                            @foreach (var p in Model.Products)
                                            {
                                                <option value="@p.Value">@p.Text</option>
                                            }
                                        </select>
                                    </td>
                                    <td>
                                        <input type="text" name="ImportRequest.Items[@i].Name" class="form-control new-product-field @(isExisting ? "bg-light" : "")" placeholder="Name" value="@Model.ImportRequest.Items[i].Name" @(isExisting ? "disabled" : "") />
                                    </td>
                                    <td>
                                        <select class="form-select new-product-field @(isExisting ? "bg-light" : "")" asp-for="ImportRequest.Items[i].CategoryId" disabled="@(isExisting ? "disabled" : null)">
                                            <option value="">-- Select Category --</option>
                                            @foreach (var c in Model.Categories)
                                            {
                                                <option value="@c.Value">@c.Text</option>
                                            }
                                        </select>
                                    </td>
                                    <td>
                                        <input type="text" name="ImportRequest.Items[@i].Unit" class="form-control new-product-field @(isExisting ? "bg-light" : "")" placeholder="Unit" value="@Model.ImportRequest.Items[i].Unit" @(isExisting ? "disabled" : "") />
                                    </td>
                                    <td>
                                        <input type="number" name="ImportRequest.Items[@i].Quantity" class="form-control quantity-input" required min="1" value="@(Model.ImportRequest.Items[i].Quantity > 0 ? Model.ImportRequest.Items[i].Quantity : 1)" />
                                    </td>
                                    <td>
                                        <input type="number" step="0.01" name="ImportRequest.Items[@i].ImportPrice" class="form-control price-input" required min="0.01" value="@(Model.ImportRequest.Items[i].ImportPrice > 0 ? Model.ImportRequest.Items[i].ImportPrice : "")" />
                                    </td>
                                    <td>
                                        @if (isExisting)
                                        {
                                            <input type="text" class="form-control bg-light text-muted multiplier-display" placeholder="From product" disabled title="Multiplier is fixed for existing products" />
                                        }
                                        else
                                        {
                                            <input type="number" step="0.01" name="ImportRequest.Items[@i].PriceMultiplier"
                                                   class="form-control multiplier-input" min="0.01" max="10"
                                                   placeholder="e.g. 1.5"
                                                   value="@(Model.ImportRequest.Items[i].PriceMultiplier.HasValue ? Model.ImportRequest.Items[i].PriceMultiplier : "")" />
                                        }
                                    </td>
                                    <td>
                                        <input type="file" name="imageFiles[@i]" accept="image/jpeg,image/png,image/webp"
                                               class="form-control image-upload new-product-field @(isExisting ? "bg-light" : "")"
                                               @(isExisting ? "disabled" : "") />
                                        <div class="form-text text-muted small">Max 3MB · jpg/jpeg/png/webp</div>
                                    </td>
                                    <td class="text-center">
                                        <button type="button" class="btn btn-sm btn-outline-danger remove-row" title="Remove">❌</button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <div class="d-flex justify-content-between mt-3">
                <button type="button" class="btn btn-outline-primary" id="addRowBtn">
                    ➕ Add Row
                </button>
                <button type="button" class="btn btn-success px-4" id="submitBtn">
                    💾 Save Import Receipt
                </button>
            </div>

            <input type="hidden" name="ReloadIndex" id="reloadIndex" value="" />
            <button type="submit" asp-page-handler="ReloadRow" id="reloadBtn" class="d-none">Reload</button>
        </form>
    </div>
</div>

<!-- ── Preview Modal ──────────────────────────────────────────────────────── -->
<div class="modal fade" id="previewModal" tabindex="-1" aria-labelledby="previewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold" id="previewModalLabel">🔍 Import Preview — Review Before Confirming</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <div class="table-responsive">
                    <table class="table table-bordered table-striped align-middle mb-0" id="previewTable">
                        <thead class="table-dark">
                            <tr>
                                <th>Product</th>
                                <th class="text-end">Qty</th>
                                <th class="text-end">Import Price</th>
                                <th class="text-end">Avg Import Price <small class="fw-normal">(after import)</small></th>
                                <th class="text-end">Multiplier</th>
                                <th class="text-end">Selling Price <small class="fw-normal">(new)</small></th>
                            </tr>
                        </thead>
                        <tbody id="previewBody">
                        </tbody>
                        <tfoot id="previewFoot" class="table-light fw-bold">
                        </tfoot>
                    </table>
                </div>
                <div id="previewErrors" class="alert alert-danger mx-3 mt-3 d-none"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">✏️ Edit</button>
                <button type="button" class="btn btn-success px-4" id="confirmSaveBtn">✅ Confirm &amp; Save</button>
            </div>
        </div>
    </div>
</div>

<!-- Template for a new row (hidden) -->
<template id="rowTemplate">
    <tr>
        <td>
            <select name="ImportRequest.Items[{0}].ProductId" class="form-select product-select">
                @foreach (var p in Model.Products)
                {
                    <option value="@p.Value">@p.Text</option>
                }
            </select>
        </td>
        <td>
            <input type="text" name="ImportRequest.Items[{0}].Name" class="form-control new-product-field" placeholder="Name" />
        </td>
        <td>
            <select name="ImportRequest.Items[{0}].CategoryId" class="form-select new-product-field">
                <option value="">-- Select Category --</option>
                @foreach (var c in Model.Categories)
                {
                    <option value="@c.Value">@c.Text</option>
                }
            </select>
        </td>
        <td>
            <input type="text" name="ImportRequest.Items[{0}].Unit" class="form-control new-product-field" placeholder="Unit" />
        </td>
        <td>
            <input type="number" name="ImportRequest.Items[{0}].Quantity" class="form-control quantity-input" required min="1" value="1" />
        </td>
        <td>
            <input type="number" step="0.01" name="ImportRequest.Items[{0}].ImportPrice" class="form-control price-input" required min="0.01" placeholder="0.00" />
        </td>
        <td>
            <input type="number" step="0.01" name="ImportRequest.Items[{0}].PriceMultiplier"
                   class="form-control multiplier-input" min="0.01" max="10" placeholder="e.g. 1.5" />
        </td>
        <td>
            <input type="file" name="imageFiles[{0}]" accept="image/jpeg,image/png,image/webp"
                   class="form-control image-upload new-product-field" />
            <div class="form-text text-muted small">Max 3MB · jpg/jpeg/png/webp</div>
        </td>
        <td class="text-center">
            <button type="button" class="btn btn-sm btn-outline-danger remove-row" title="Remove">❌</button>
        </td>
    </tr>
</template>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // ── Product metadata injected from server ──────────────────────────────
        // Shape: { "productId": { stock, avgPrice, multiplier } }
        const productMeta = @Html.Raw(Model.ProductMetaJson);

        document.addEventListener('DOMContentLoaded', function () {
            let rowCount = document.querySelectorAll('#itemsBody tr').length;
            const tbody = document.getElementById('itemsBody');
            const addRowBtn = document.getElementById('addRowBtn');
            const template = document.getElementById('rowTemplate').innerHTML;

            // ── Helper: format currency ──────────────────────────────────────
            function fmt(n) {
                return n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            }

            // ── Preview calculation ──────────────────────────────────────────
            function buildPreview() {
                const rows = tbody.querySelectorAll('tr');
                const errors = [];
                const previewRows = [];
                let totalCost = 0;

                rows.forEach((row, idx) => {
                    const productSelect = row.querySelector('.product-select');
                    const qtyInput = row.querySelector('.quantity-input');
                    const priceInput = row.querySelector('.price-input');
                    const multiplierInput = row.querySelector('.multiplier-input');
                    const multiplierDisplay = row.querySelector('.multiplier-display');

                    const productId = productSelect ? productSelect.value : '';
                    const qty = parseInt(qtyInput ? qtyInput.value : '0') || 0;
                    const importPrice = parseFloat(priceInput ? priceInput.value : '0') || 0;

                    // Determine product name
                    let productName = '(New Product)';
                    if (productSelect) {
                        const opt = productSelect.options[productSelect.selectedIndex];
                        productName = opt ? opt.text : '(New Product)';
                    }

                    if (qty <= 0) { errors.push(`Row ${idx + 1}: Quantity must be > 0.`); return; }
                    if (importPrice <= 0) { errors.push(`Row ${idx + 1}: Import price must be > 0.`); return; }

                    let avgPrice, multiplier, isExisting;

                    if (productId) {
                        // ── Existing product ──────────────────────────────
                        isExisting = true;
                        const meta = productMeta[productId];
                        if (!meta) { errors.push(`Row ${idx + 1}: Product data not found.`); return; }
                        const oldStock = meta.stock;
                        const oldAvgPrice = meta.avgPrice;
                        multiplier = meta.multiplier;

                        avgPrice = (oldStock + qty) > 0
                            ? ((oldStock * oldAvgPrice) + (qty * importPrice)) / (oldStock + qty)
                            : importPrice;
                    } else {
                        // ── New product ───────────────────────────────────
                        isExisting = false;
                        multiplier = parseFloat(multiplierInput ? multiplierInput.value : '0') || 0;
                        if (multiplier <= 0) { errors.push(`Row ${idx + 1}: Multiplier is required for new products.`); return; }
                        avgPrice = importPrice;
                    }

                    const sellingPrice = avgPrice * multiplier;
                    totalCost += qty * importPrice;

                    previewRows.push({
                        name: productName,
                        qty,
                        importPrice,
                        avgPrice,
                        multiplier,
                        sellingPrice,
                        isExisting
                    });
                });

                return { errors, previewRows, totalCost };
            }

            // ── Show preview modal ───────────────────────────────────────────
            document.getElementById('submitBtn').addEventListener('click', function () {
                const { errors, previewRows, totalCost } = buildPreview();

                const errBox = document.getElementById('previewErrors');
                const previewBody = document.getElementById('previewBody');
                const previewFoot = document.getElementById('previewFoot');

                previewBody.innerHTML = '';
                previewFoot.innerHTML = '';

                if (errors.length > 0) {
                    errBox.innerHTML = '<strong>Please fix these issues:</strong><ul>' +
                        errors.map(e => `<li>${e}</li>`).join('') + '</ul>';
                    errBox.classList.remove('d-none');
                } else {
                    errBox.classList.add('d-none');
                }

                if (previewRows.length === 0 && errors.length === 0) {
                    errBox.textContent = 'No valid rows to preview.';
                    errBox.classList.remove('d-none');
                }

                previewRows.forEach(r => {
                    const tr = document.createElement('tr');
                    tr.innerHTML = `
                        <td>${r.name} ${r.isExisting ? '' : '<span class="badge bg-info text-dark ms-1">New</span>'}</td>
                        <td class="text-end">${r.qty}</td>
                        <td class="text-end">${fmt(r.importPrice)}</td>
                        <td class="text-end fw-semibold">${fmt(r.avgPrice)}</td>
                        <td class="text-end">${r.multiplier.toFixed(2)}×</td>
                        <td class="text-end text-success fw-bold">${fmt(r.sellingPrice)}</td>
                    `;
                    previewBody.appendChild(tr);
                });

                if (previewRows.length > 0) {
                    previewFoot.innerHTML = `
                        <tr>
                            <td colspan="2"></td>
                            <td colspan="2" class="text-end">Total Import Cost:</td>
                            <td colspan="2" class="text-end">${fmt(totalCost)}</td>
                        </tr>
                    `;
                }

                const modal = new bootstrap.Modal(document.getElementById('previewModal'));
                modal.show();
            });

            // ── Confirm button submits the form ──────────────────────────────
            document.getElementById('confirmSaveBtn').addEventListener('click', function () {
                const modal = bootstrap.Modal.getInstance(document.getElementById('previewModal'));
                if (modal) modal.hide();
                document.getElementById('importForm').submit();
            });

            // ── Row event attachment ─────────────────────────────────────────
            function attachEventsToRow(row) {
                const productSelect = row.querySelector('.product-select');
                const newFields = row.querySelectorAll('.new-product-field');
                const multiplierInput = row.querySelector('.multiplier-input');

                const toggleFields = (e) => {
                    const isNew = !productSelect.value;

                    if (!isNew) {
                        // Duplicate check
                        const allSelects = document.querySelectorAll('.product-select');
                        let count = 0;
                        allSelects.forEach(s => { if (s.value === productSelect.value) count++; });
                        if (count > 1) {
                            alert("This product has already been added in another row.");
                            productSelect.value = "";
                            toggleFields();
                            return;
                        }

                        if (e && e.type === 'change') {
                            const index = Array.from(tbody.children).indexOf(row);
                            document.getElementById('reloadIndex').value = index;
                            document.getElementById('reloadBtn').click();
                        }

                        newFields.forEach(f => {
                            f.disabled = true;
                            f.classList.add('bg-light');
                        });
                        // Hide new-product multiplier; show read-only display instead
                        if (multiplierInput) {
                            multiplierInput.disabled = true;
                            multiplierInput.classList.add('d-none');
                            // Insert a placeholder display if none
                            let disp = row.querySelector('.multiplier-display');
                            if (!disp) {
                                disp = document.createElement('input');
                                disp.type = 'text';
                                disp.className = 'form-control bg-light text-muted multiplier-display';
                                disp.disabled = true;
                                disp.placeholder = 'From product';
                                disp.title = 'Multiplier is fixed for existing products';
                                multiplierInput.parentNode.appendChild(disp);
                            }
                            disp.classList.remove('d-none');
                        }
                    } else {
                        newFields.forEach(f => {
                            f.disabled = false;
                            f.classList.remove('bg-light');
                            if (e && e.type === 'change') f.value = '';
                        });
                        if (multiplierInput) {
                            multiplierInput.disabled = false;
                            multiplierInput.classList.remove('d-none');
                            const disp = row.querySelector('.multiplier-display');
                            if (disp) disp.classList.add('d-none');
                        }
                    }
                };

                productSelect.addEventListener('change', toggleFields);
                // Initialise state without firing a reload
                toggleFields(null);
            }

            function addRow() {
                const newRowHtml = template.replace(/\{0\}/g, rowCount);
                tbody.insertAdjacentHTML('beforeend', newRowHtml);
                const newRow = tbody.lastElementChild;
                attachEventsToRow(newRow);
                rowCount++;
            }

            // Remove row (delegated)
            tbody.addEventListener('click', function (e) {
                if (e.target.closest('.remove-row')) {
                    e.target.closest('tr').remove();
                    reindexRows();
                }
            });

            function reindexRows() {
                const rows = tbody.querySelectorAll('tr');
                rows.forEach((row, index) => {
                    row.querySelectorAll('[name]').forEach(input => {
                        const name = input.getAttribute('name');
                        const newName = name.replace(/Items\[\d+\]/, `Items[${index}]`);
                        input.setAttribute('name', newName);
                    });
                    row.querySelectorAll('input[type="file"]').forEach(input => {
                        input.setAttribute('name', `imageFiles[${index}]`);
                    });
                });
                rowCount = rows.length;
            }

            // Attach events to existing server-rendered rows
            document.querySelectorAll('#itemsBody tr').forEach(row => attachEventsToRow(row));

            // Add first row if table is empty
            if (rowCount === 0) addRow();

            addRowBtn.addEventListener('click', addRow);
        });
    </script>
}
