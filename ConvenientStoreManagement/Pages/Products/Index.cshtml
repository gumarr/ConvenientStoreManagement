@page
@model ConvenientStoreManagement.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Product Management</h2>
    <a asp-page="Create" class="btn btn-primary">Create New</a>
</div>

<form method="get" class="mb-4">
    <div class="row g-3">
        <div class="col-md-4">
            <input type="text" name="search" value="@Model.CurrentSearch" class="form-control" placeholder="Search by name..." />
        </div>
        <div class="col-md-3">
            <select name="categoryId" asp-items="Model.CategoryList" class="form-select">
                <option value="">All Categories</option>
            </select>
        </div>
        <div class="col-md-3">
            <select name="sortOrder" class="form-select">
                <option value="name_asc" selected="@(Model.CurrentSort == "name_asc")">Name (A-Z)</option>
                <option value="price_asc" selected="@(Model.CurrentSort == "price_asc")">Price (Low to High)</option>
                <option value="price_desc" selected="@(Model.CurrentSort == "price_desc")">Price (High to Low)</option>
            </select>
        </div>
        <div class="col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
            <a asp-page="./Index" class="btn btn-outline-secondary">Clear</a>
        </div>
    </div>
</form>

<div class="table-responsive bg-white rounded shadow-sm">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>Image</th>
                <th>Name</th>
                <th>Category</th>
                <th>Price</th>
                <th>Stock</th>
                <th>Status</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Products)
            {
                <tr>
                    <td>
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" alt="@item.Name" style="width: 50px; height: 50px; object-fit: cover;" class="rounded" />
                        }
                        else
                        {
                            <div class="bg-light rounded d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                <span class="text-muted small">N/A</span>
                            </div>
                        }
                    </td>
                    <td class="fw-medium">@item.Name</td>
                    <td><span class="badge bg-secondary">@item.CategoryName</span></td>
                    <td>@Html.DisplayFor(modelItem => item.Price)</td>
                    <td>
                        <span class="badge @(item.Stock > 10 ? "bg-success" : (item.Stock > 0 ? "bg-warning" : "bg-danger"))">
                            @item.Stock
                        </span>
                    </td>
                    <td>
                        <span class="badge @(item.Status == "Active" ? "bg-primary" : "bg-dark")">@item.Status</span>
                    </td>
                    <td class="text-end">
                        <a asp-page="./Edit" asp-route-id="@item.ProductId" class="btn btn-sm btn-outline-primary">Edit</a>
                        <a asp-page="./Delete" asp-route-id="@item.ProductId" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
            @if (!Model.Products.Any())
            {
                <tr>
                    <td colspan="7" class="text-center py-4 text-muted">No products found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@{
    var prevDisabled = !Model.Products.HasPreviousPage ? "disabled" : "";
    var nextDisabled = !Model.Products.HasNextPage ? "disabled" : "";
}

<div class="d-flex justify-content-between align-items-center mt-4">
    <span class="text-muted">Page @Model.Products.PageIndex of @Model.Products.TotalPages</span>
    <div class="btn-group">
        <a asp-page="./Index"
           asp-route-pageIndex="@(Model.Products.PageIndex - 1)"
           asp-route-search="@Model.CurrentSearch"
           asp-route-categoryId="@Model.CurrentCategory"
           asp-route-sortOrder="@Model.CurrentSort"
           class="btn btn-outline-primary @prevDisabled">
            Previous
        </a>
        <a asp-page="./Index"
           asp-route-pageIndex="@(Model.Products.PageIndex + 1)"
           asp-route-search="@Model.CurrentSearch"
           asp-route-categoryId="@Model.CurrentCategory"
           asp-route-sortOrder="@Model.CurrentSort"
           class="btn btn-outline-primary @nextDisabled">
            Next
        </a>
    </div>
</div>
