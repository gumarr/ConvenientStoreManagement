@page
@model ConvenientStoreManagement.Pages.Products.EditModel

@{
    ViewData["Title"] = "Edit Product";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h2>@ViewData["Title"]</h2>
            <hr />

            <form method="post">
                <input type="hidden" asp-for="Product.ProductId" />
                <input type="hidden" asp-for="Product.CreatedDate" />

                <div class="mb-3">
                    <label asp-for="Product.ProductName" class="form-label">Product Name</label>
                    <input asp-for="Product.ProductName" class="form-control" />
                    <span asp-validation-for="Product.ProductName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Product.Description" class="form-label">Description</label>
                    <textarea asp-for="Product.Description" class="form-control" rows="3"></textarea>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Product.Price" class="form-label">Price</label>
                        <input asp-for="Product.Price" class="form-control" step="0.01" />
                        <span asp-validation-for="Product.Price" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Product.CostPrice" class="form-label">Cost Price</label>
                        <input asp-for="Product.CostPrice" class="form-control" step="0.01" />
                        <span asp-validation-for="Product.CostPrice" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Product.Quantity" class="form-label">Quantity</label>
                        <input asp-for="Product.Quantity" class="form-control" type="number" />
                        <span asp-validation-for="Product.Quantity" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Product.CategoryId" class="form-label">Category</label>
                        <select asp-for="Product.CategoryId" asp-items="Model.CategoryList" class="form-control">
                            <option value="">-- Select Category --</option>
                        </select>
                        <span asp-validation-for="Product.CategoryId" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="Product.IsActive" class="form-check-input" />
                    <label asp-for="Product.IsActive" class="form-check-label">Active</label>
                </div>

                <div class="mb-3">
                    <button type="submit" class="btn btn-primary">Update</button>
                    <a asp-page="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
