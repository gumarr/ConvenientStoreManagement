@page
@model ConvenientStoreManagement.Pages.Products.CreateModel

@{
  ViewData["Title"] = "Create Product";
}

<div class="container mt-4">
  <div class="row">
    <div class="col-md-8 offset-md-2">
      <h2>@ViewData["Title"]</h2>
      <hr />

      @if (!Model.CategoryList.Any())
      {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
          <strong>⚠️ Cannot create product!</strong> You need to create at least one category first.
          <a asp-page="/Categories/Create" class="btn btn-sm btn-primary ms-2">Create Category</a>
        </div>
      }

      @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Any())
      {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
          <strong>❌ Validation Error!</strong> Please fix the following:
          <ul class="mb-0 mt-2">
            @foreach (var entry in ViewData.ModelState)
            {
              @foreach (var error in entry.Value.Errors)
              {
                <li>@error.ErrorMessage</li>
              }
            }
          </ul>
        </div>
      }

      <form method="post">
        <div class="mb-3">
          <label asp-for="Product.ProductName" class="form-label">Product Name <span
            class="text-danger">*</span></label>
            <input asp-for="Product.ProductName" class="form-control" required />
            <span asp-validation-for="Product.ProductName" class="text-danger"></span>
          </div>

          <div class="mb-3">
            <label asp-for="Product.Description" class="form-label">Description</label>
            <textarea asp-for="Product.Description" class="form-control" rows="3"></textarea>
          </div>

          <div class="row">
            <div class="col-md-6 mb-3">
              <label asp-for="Product.Price" class="form-label">Price <span class="text-danger">*</span></label>
              <input asp-for="Product.Price" class="form-control" step="0.01" required />
              <span asp-validation-for="Product.Price" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3">
              <label asp-for="Product.CostPrice" class="form-label">Cost Price <span class="text-danger">*</span></label>
              <input asp-for="Product.CostPrice" class="form-control" step="0.01" required />
              <span asp-validation-for="Product.CostPrice" class="text-danger"></span>
            </div>
          </div>

          <div class="row">
            <div class="col-md-6 mb-3">
              <label asp-for="Product.Quantity" class="form-label">Quantity <span class="text-danger">*</span></label>
              <input asp-for="Product.Quantity" class="form-control" type="number" required />
              <span asp-validation-for="Product.Quantity" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3">
              <label asp-for="Product.CategoryId" class="form-label">Category <span class="text-danger">*</span></label>
              <select asp-for="Product.CategoryId" asp-items="Model.CategoryList" class="form-control" required>
                <option value="">-- Select Category --</option>
              </select>
              <span asp-validation-for="Product.CategoryId" class="text-danger"></span>
            </div>
          </div>

          <div class="mb-3 form-check">
            <input asp-for="Product.IsActive" class="form-check-input" id="isActive" />
            <label asp-for="Product.IsActive" class="form-check-label" for="isActive">Active</label>
          </div>

          <div class="mb-3">
            <button type="submit" class="btn btn-primary">Create
              Product</button>
              <a asp-page="Index" class="btn btn-secondary">Cancel</a>
            </div>
          </form>
        </div>
      </div>
    </div>

    @section Scripts {
      @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
      }
    }
