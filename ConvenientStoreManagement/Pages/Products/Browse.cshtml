@page
@model ConvenientStoreManagement.Pages.Products.BrowseModel

@{
    ViewData["Title"] = "Browse Products";
    ViewData["IsFullWidth"] = true;
}

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/product-browse.css" asp-append-version="true" />
}

@Html.AntiForgeryToken()

<div class="browse-layout">

    <!-- ══════════════════════════════════════════════
         SIDEBAR
    ══════════════════════════════════════════════ -->
    <aside class="browse-sidebar">

        <!-- Brand -->
        <div class="sidebar-brand">
            <div class="sidebar-brand-icon"><i class="fas fa-store"></i></div>
            <span>Convenient Store</span>
        </div>

        <!-- Search -->
        <section class="sidebar-section">
            <p class="sidebar-label"><i class="fas fa-search sidebar-label-icon"></i> TÌM KIẾM</p>
            <form method="get" asp-page="/Products/Browse" id="searchForm">
                <input type="hidden" name="categoryId" value="@Model.CurrentCategory" />
                <input type="hidden" name="pageIndex" value="1" />
                <div class="search-wrap">
                    <i class="fas fa-search"></i>
                    <input type="text"
                           name="searchString"
                           id="searchInput"
                           placeholder="Tên sản phẩm…"
                           value="@Model.CurrentSearch"
                           autocomplete="off" />
                    <button type="submit" class="search-btn" title="Search">
                        <i class="fas fa-arrow-right"></i>
                    </button>
                </div>
            </form>
        </section>

        <!-- Categories -->
        <section class="sidebar-section">
            <p class="sidebar-label"><i class="fas fa-th-list sidebar-label-icon"></i> DANH MỤC</p>
            <ul class="cat-list">
                <li>
                    <a class="cat-link @(Model.CurrentCategory == null ? "active" : "")"
                       asp-page="/Products/Browse"
                       asp-route-searchString="@Model.CurrentSearch"
                       asp-route-pageIndex="1">
                        <i class="fas fa-border-all cat-icon"></i>
                        <span>Tất Cả</span>
                        <span class="cat-pill">@Model.TotalProducts</span>
                    </a>
                </li>
                @foreach (var cat in Model.Categories)
                {
                    <li>
                        <a class="cat-link @(Model.CurrentCategory == cat.CategoryId ? "active" : "")"
                           asp-page="/Products/Browse"
                           asp-route-searchString="@Model.CurrentSearch"
                           asp-route-categoryId="@cat.CategoryId"
                           asp-route-pageIndex="1">
                            <i class="fas fa-tag cat-icon"></i>
                            <span>@cat.Name</span>
                        </a>
                    </li>
                }
            </ul>
        </section>

        <!-- Sort -->
        <section class="sidebar-section">
            <p class="sidebar-label"><i class="fas fa-sort sidebar-label-icon"></i> SẮP XẾP</p>
            <ul class="sort-list">
                <li class="sort-link active" data-sort="default">
                    <i class="fas fa-star sort-icon"></i> Tất cả
                </li>
                <li class="sort-link" data-sort="price-asc">
                    Giá: Thấp <i class="fas fa-arrow-right mx-1 text-xs"></i> Cao
                </li>
                <li class="sort-link" data-sort="price-desc">
                    Giá: Cao <i class="fas fa-arrow-right mx-1 text-xs"></i> Thấp
                </li>
                <li class="sort-link" data-sort="name-asc">
                    Tên: A <i class="fas fa-arrow-right mx-1 text-xs"></i> Z
                </li>
            </ul>
        </section>

    </aside>

    <!-- ══════════════════════════════════════════════
         MAIN CONTENT
    ══════════════════════════════════════════════ -->
    <main class="browse-main container-fluid p-0">
        <div class="row m-0">
            <!-- CỘT 8: Khu vực Danh sách sản phẩm -->
            <div class="col-md-8 pb-3">

        <!-- Top bar -->
        <div class="main-topbar">
            <div class="main-count">
                <span id="visibleCount">@Model.TotalProducts</span> sản phẩm
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.CurrentSearch))
            {
                <span class="active-filter-badge">
                    <i class="fas fa-search"></i> "@Model.CurrentSearch"
                    <a asp-page="/Products/Browse"
                       asp-route-categoryId="@Model.CurrentCategory"
                       class="clear-filter" title="Clear search">
                        <i class="fas fa-times"></i>
                    </a>
                </span>
            }
            @if (Model.CurrentCategory.HasValue)
            {
                <span class="active-filter-badge">
                    <i class="fas fa-tag"></i> @(Model.Categories.FirstOrDefault(c => c.CategoryId == Model.CurrentCategory)?.Name ?? "Category")
                    <a asp-page="/Products/Browse"
                       asp-route-searchString="@Model.CurrentSearch"
                       class="clear-filter" title="Clear category">
                        <i class="fas fa-times"></i>
                    </a>
                </span>
            }
        </div>

        <!-- Product Grid -->
        <div id="productGrid" class="product-grid">

            @if (!Model.Products.Any())
            {
                <div class="empty-state">
                    <i class="fas fa-box-open"></i>
                    <p>Không tìm thấy sản phẩm</p>
                    <span>Thử thay đổi từ khóa hoặc danh mục.</span>
                </div>
            }

            @foreach (var item in Model.Products)
            {
                // Status Handling requirement: Use the BIT status (item.Status)
                bool inStock = item.Status;

                // Price: use the ACTIVE price (EndDate IS NULL), ordered by StartDate descending
                decimal price = item.ProductPrices?
                    .Where(pp => pp.EndDate == null)
                    .OrderByDescending(pp => pp.StartDate)
                    .FirstOrDefault()?.Price ?? 0;

                <div class="p-card @(!inStock ? "oos" : "")"
                     data-name="@item.Name.ToLower()"
                     data-price="@price"
                     data-stock="@item.Stock">

                    <!-- Image -->
                    <div class="p-img">
    @{
        // Mặc định sử dụng placeholder nếu ImageUrl trống
        string displayUrl = "/img/placeholder.png"; 

        if (!string.IsNullOrWhiteSpace(item.ImageUrl))
        {
            displayUrl = item.ImageUrl.Replace("\\", "/");

            // Nếu đường dẫn không bắt đầu bằng http hoặc / thì thêm dấu / ở đầu
            if (!displayUrl.StartsWith("http") && !displayUrl.StartsWith("/"))
            {
                displayUrl = "/" + displayUrl;
            }
        }
    }
    
    <img src="@displayUrl" 
         onerror="this.src='/img/placeholder.png'" 
         alt="@item.Name" 
         loading="lazy" />

    @if (inStock)
    {
        <span class="badge badge-in">In Stock</span>
    }
    else
    {
        <span class="badge badge-oos">Out of Stock</span>
    }
</div>

                    <!-- Body -->
                    <div class="p-body">

                        <!-- Category label -->
                        <span class="p-category">@(item.Category?.Name ?? "General")</span>

                        <!-- Name -->
                        <h3 class="p-name" title="@item.Name">@item.Name</h3>

                        <div class="p-spacer"></div>

                        <!-- Unit -->
                        @if (!string.IsNullOrWhiteSpace(item.Unit))
                        {
                            <div class="p-unit">
                                <i class="fas fa-box-open"></i> @item.Unit
                            </div>
                        }

                        <!-- Price + Cart -->
                        <div class="p-footer">
                            <div class="p-price">
                                @price.ToString("N0") <span class="currency">VNĐ</span>
                            </div>

                            <div class="d-flex gap-1 align-items-center">
                                <a asp-page="/Products/Details"
                                   asp-route-id="@item.ProductId"
                                   class="btn btn-sm btn-outline-secondary"
                                   title="View Details"
                                   style="border-radius:8px; height:36px; display:inline-flex; align-items:center; padding:0 .6rem;">
                                    <i class="fas fa-info-circle"></i>
                                </a>
                                <button class="cart-btn"
                                        id="cart-@item.ProductId"
                                        title="@(inStock ? "Add to Cart" : "Out of Stock")"
                                        @(inStock ? "" : "disabled")
                                        onclick="addToCart(this, @item.ProductId, '@Html.Raw(item.Name.Replace("'", "\\'"))')">
                                    <i class="fas fa-plus"></i>
                                    <span>Add to Cart</span>
                                </button>
                            </div>
                        </div>

                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <nav class="pagination-nav" aria-label="Product pagination">

                @* Previous *@
                @if (Model.PageIndex > 1)
                {
                    <a class="page-btn page-nav"
                       asp-page="/Products/Browse"
                       asp-route-searchString="@Model.CurrentSearch"
                       asp-route-categoryId="@Model.CurrentCategory"
                       asp-route-pageIndex="@(Model.PageIndex - 1)">
                        <i class="fas fa-chevron-left"></i> Previous
                    </a>
                }
                else
                {
                    <span class="page-btn page-nav disabled">
                        <i class="fas fa-chevron-left"></i> Previous
                    </span>
                }

                @* Page numbers *@
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    if (i == Model.PageIndex)
                    {
                        <span class="page-btn active">@i</span>
                    }
                    else if (i == 1 || i == Model.TotalPages || Math.Abs(i - Model.PageIndex) <= 2)
                    {
                        <a class="page-btn"
                           asp-page="/Products/Browse"
                           asp-route-searchString="@Model.CurrentSearch"
                           asp-route-categoryId="@Model.CurrentCategory"
                           asp-route-pageIndex="@i">@i</a>
                    }
                    else if (Math.Abs(i - Model.PageIndex) == 3)
                    {
                        <span class="page-btn ellipsis">…</span>
                    }
                }

                @* Next *@
                @if (Model.PageIndex < Model.TotalPages)
                {
                    <a class="page-btn page-nav"
                       asp-page="/Products/Browse"
                       asp-route-searchString="@Model.CurrentSearch"
                       asp-route-categoryId="@Model.CurrentCategory"
                       asp-route-pageIndex="@(Model.PageIndex + 1)">
                        Next <i class="fas fa-chevron-right"></i>
                    </a>
                }
                else
                {
                    <span class="page-btn page-nav disabled">
                        Next <i class="fas fa-chevron-right"></i>
                    </span>
                }

            </nav>
        }

            </div> <!-- /col-md-8 -->

            <!-- CỘT 4: Khu vực Giỏ hàng (POS) -->
            <div class="col-md-4 bg-light bg-gradient border-start py-3" style="min-height: 100vh;">
                <div class="cart-panel bg-white rounded shadow-sm p-4 sticky-top" style="top: 20px;">
                    <h4 class="border-bottom pb-3 mb-4 fw-bold text-primary">
                        <i class="fas fa-shopping-cart me-2"></i> POS Giỏ Hàng
                    </h4>

                    <!-- ═══════════════════════════════════════════
                         MEMBER SEARCH SECTION
                    ═══════════════════════════════════════════ -->
                    <div class="member-section mb-4 p-3 border rounded-3 bg-gradient" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-color: transparent !important;">
                        <h6 class="text-white fw-bold mb-3">
                            <i class="fas fa-id-card me-2"></i> Thẻ Thành Viên
                        </h6>

                        <!-- Current Member Info -->
                        <div id="memberInfo" class="mb-3 p-2 rounded bg-white" style="display: none;">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <div class="fw-bold text-dark" id="memberName">-</div>
                                    <div class="small text-muted" id="memberPhone">SĐT: -</div>
                                    <div class="text-primary fw-semibold" id="memberPoints">Điểm: 0</div>
                                </div>
                                <button class="btn btn-sm btn-light" onclick="clearMember()" title="Xóa">
                                    <i class="fas fa-times"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Search Input -->
                        <div class="input-group mb-2" style="gap: 5px;">
                            <input type="tel" id="searchMemberPhone" class="form-control form-control-sm" 
                                   placeholder="Nhập SĐT khách..." autocomplete="off" />
                            <button class="btn btn-sm btn-light fw-bold" onclick="searchMember()" title="Tìm kiếm">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>

                        <!-- Create Member Button -->
                        <button class="btn btn-sm btn-light w-100 fw-bold" onclick="openCreateMemberModal()">
                            <i class="fas fa-user-plus me-1"></i> Tạo Thành Viên Mới
                        </button>

                        <!-- Loading Spinner -->
                        <div id="memberLoadingSpinner" class="text-center text-white mt-2" style="display: none;">
                            <div class="spinner-border spinner-border-sm" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>

                        <!-- Error/Success Message -->
                        <div id="memberMessage" class="alert mt-2 mb-0 py-2" style="display: none; font-size: 0.85rem;"></div>
                    </div>

                    <!-- Separator -->
                    <hr class="my-3" />
                    
                    <!-- Danh sách items -->
                    <div id="cartItems" class="mb-4" style="max-height: 400px; overflow-y: auto; overflow-x: hidden;">
                        <div class="text-center text-muted py-4">
                            <i class="fas fa-box-open fs-1 text-light mb-3"></i>
                            <p class="mb-0">Giỏ hàng đang trống!</p>
                        </div>
                    </div>

                    <hr class="text-secondary mb-4" />

                    <!-- Box sử dụng điểm tích lũy -->
                    <div class="mb-4">
                        <label for="loyaltyPointsToUse" class="form-label fw-semibold">
                            <i class="fas fa-star text-warning me-2"></i>Sử Dụng Điểm Tích Lũy
                        </label>
                        <div class="input-group">
                            <input type="number" id="loyaltyPointsToUse" class="form-control" placeholder="Nhập số điểm (1:1 VNĐ)" min="0" value="0" onchange="updatePointsDiscount()">
                            <button class="btn btn-outline-warning fw-bold" onclick="applyLoyaltyPoints()">Áp dụng</button>
                        </div>
                        <small id="pointsAvailable" class="text-muted d-block mt-2">Điểm khả dụng: <strong id="availablePoints">0</strong></small>
                    </div>

                    <!-- Tổng tiền -->
                    <div class="bg-light rounded p-3 mb-4">
                        <div class="d-flex justify-content-between mb-2 text-muted">
                            <span>Tạm tính:</span>
                            <strong id="cartSubtotal" class="text-dark">0 VNĐ</strong>
                        </div>
                        <div class="d-flex justify-content-between mb-3 text-muted" id="pointsDiscountRow" style="display: none;">
                            <span>Trừ điểm tích lũy:</span>
                            <strong id="cartPointsDiscount" class="text-success">0 VNĐ</strong>
                        </div>
                        <div class="d-flex justify-content-between align-items-center border-top pt-3">
                            <span class="fs-5 fw-bold text-dark">Tổng cộng:</span>
                            <strong id="cartTotal" class="fs-4 text-danger mb-0">0 VNĐ</strong>
                        </div>
                    </div>

                    <button class="btn btn-primary w-100 py-3 fw-bold fs-5 shadow-sm" onclick="checkout()">
                        <i class="fas fa-credit-card me-2"></i> Đã thanh toán
                    </button>
                </div>
            </div> <!-- /col-md-4 -->

        </div> <!-- /row -->
    </main>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════
     MODAL: CREATE NEW MEMBER
     ═══════════════════════════════════════════════════════════════════════ -->
<div class="modal fade" id="createMemberModal" tabindex="-1" aria-labelledby="createMemberLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold" id="createMemberLabel">
                    <i class="fas fa-user-plus me-2"></i> Tạo Thẻ Thành Viên Mới
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="createMemberForm">
                    <div class="mb-3">
                        <label for="newMemberName" class="form-label fw-semibold">Tên Khách Hàng <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="newMemberName" placeholder="Nhập tên..." required />
                    </div>
                    <div class="mb-3">
                        <label for="newMemberPhone" class="form-label fw-semibold">Số Điện Thoại <span class="text-danger">*</span></label>
                        <input type="tel" class="form-control" id="newMemberPhone" placeholder="Nhập SĐT..." required />
                    </div>
                    <div class="mb-3">
                        <label for="newMemberEmail" class="form-label fw-semibold">Email <span class="text-muted">(Tùy chọn)</span></label>
                        <input type="email" class="form-control" id="newMemberEmail" placeholder="Nhập email..." />
                    </div>
                    <div id="createMemberError" class="alert alert-danger" style="display: none; margin-bottom: 0;"></div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary fw-bold" onclick="confirmCreateMember()">
                    <i class="fas fa-check me-1"></i> Tạo Thành Viên
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
/* ─────────────────────────────────────────────────────────────
   Client-side sort (reorders already-loaded cards without refetch)
───────────────────────────────────────────────────────────── */
function cards() { return Array.from(document.querySelectorAll('.p-card')); }

document.querySelectorAll('.sort-link').forEach(btn => {
    btn.addEventListener('click', () => {
        document.querySelectorAll('.sort-link').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const sort = btn.dataset.sort;
        const grid = document.getElementById('productGrid');
        const list = cards().sort((a, b) => {
            if (sort === 'price-asc')  return +a.dataset.price - +b.dataset.price;
            if (sort === 'price-desc') return +b.dataset.price - +a.dataset.price;
            if (sort === 'name-asc')   return a.dataset.name.localeCompare(b.dataset.name);
            return 0;
        });
        list.forEach(c => grid.appendChild(c));
    });
});

/* ─────────────────────────────────────────────────────────────
   Cart State and Logic
───────────────────────────────────────────────────────────── */
let cart = [];
let loyaltyPointsToUse = 0;
let currentMemberPoints = 0;

function addToCart(btn, productId, name) {
    if (btn.disabled) return;
    
    // Lấy giá từ dataset tĩnh trên thẻ card khi load trang
    const card = btn.closest('.p-card');
    const price = card ? parseFloat(card.dataset.price) : 0;
    
    const existingItem = cart.find(x => x.productId === productId);
    if (existingItem) {
        existingItem.quantity += 1;
    } else {
        cart.push({
            productId: productId,
            name: name,
            quantity: 1,
            unitPrice: price,
            discountApplied: 0
        });
    }

    // UI Feedback
    const icon = btn.querySelector('i');
    const label = btn.querySelector('span');
    icon.className  = 'fas fa-check';
    label.textContent = 'Added';
    btn.classList.add('btn-success');

    setTimeout(() => {
        icon.className  = 'fas fa-plus';
        label.textContent = 'Add to Cart';
        btn.classList.remove('btn-success');
    }, 1000);

    renderCart();
}

function updateQuantity(productId, change) {
    const itemIndex = cart.findIndex(x => x.productId === productId);
    if (itemIndex > -1) {
        cart[itemIndex].quantity += change;
        if (cart[itemIndex].quantity <= 0) {
            cart.splice(itemIndex, 1);
        }
        renderCart();
    }
}

function applyLoyaltyPoints() {
    const points = parseFloat(document.getElementById('loyaltyPointsToUse').value) || 0;
    
    if (points < 0) {
        alert('Số điểm không hợp lệ!');
        return;
    }
    
    if (points > currentMemberPoints) {
        alert(`Điểm không đủ! Bạn chỉ có ${currentMemberPoints} điểm.`);
        document.getElementById('loyaltyPointsToUse').value = currentMemberPoints;
        loyaltyPointsToUse = currentMemberPoints;
    } else {
        loyaltyPointsToUse = points;
    }
    
    renderCart();
}

function updatePointsDiscount() {
    const points = parseFloat(document.getElementById('loyaltyPointsToUse').value) || 0;
    if (points > currentMemberPoints) {
        document.getElementById('loyaltyPointsToUse').value = currentMemberPoints;
        loyaltyPointsToUse = currentMemberPoints;
    } else {
        loyaltyPointsToUse = Math.max(0, points);
    }
    renderCart();
}

function renderCart() {
    const cartContainer = document.getElementById('cartItems');
    let subtotal = 0;

    if (cart.length === 0) {
        cartContainer.innerHTML = '<div class="text-center text-muted py-4"><i class="fas fa-box-open fs-1 text-light mb-3"></i><p class="mb-0">Giỏ hàng đang trống!</p></div>';
        document.getElementById('cartSubtotal').textContent = '0 VNĐ';
        document.getElementById('cartPointsDiscount').textContent = '0 VNĐ';
        document.getElementById('pointsDiscountRow').style.display = 'none';
        document.getElementById('cartTotal').textContent = '0 VNĐ';
        return;
    }

    cartContainer.innerHTML = '';
    cart.forEach(item => {
        const itemTotal = item.unitPrice * item.quantity;
        subtotal += itemTotal;

        cartContainer.innerHTML += `
            <div class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom">
                <div style="flex: 1; padding-right: 10px;">
                    <div class="fw-bold fs-6 text-truncate" title="${item.name}">${item.name}</div>
                    <div class="text-primary small fw-semibold">${item.unitPrice.toLocaleString()} VNĐ</div>
                </div>
                <div class="d-flex align-items-center bg-light rounded shadow-sm">
                    <button class="btn btn-sm btn-light text-secondary px-2 focus-ring" style="min-width: 32px;" onclick="updateQuantity(${item.productId}, -1)"><i class="fas fa-minus"></i></button>
                    <span class="fw-bold px-2 text-dark" style="min-width: 30px; text-align: center;">${item.quantity}</span>
                    <button class="btn btn-sm btn-light text-secondary px-2 focus-ring" style="min-width: 32px;" onclick="updateQuantity(${item.productId}, 1)"><i class="fas fa-plus"></i></button>
                </div>
            </div>`;
    });

    const total = subtotal - loyaltyPointsToUse;
    
    document.getElementById('cartSubtotal').textContent = subtotal.toLocaleString() + ' VNĐ';
    
    if (loyaltyPointsToUse > 0) {
        document.getElementById('pointsDiscountRow').style.display = 'flex';
        document.getElementById('cartPointsDiscount').textContent = '-' + loyaltyPointsToUse.toLocaleString() + ' VNĐ';
    } else {
        document.getElementById('pointsDiscountRow').style.display = 'none';
    }
    
    document.getElementById('cartTotal').textContent = Math.max(0, total).toLocaleString() + ' VNĐ';
}

/* ─────────────────────────────────────────────────────────────
   MEMBER CARD FUNCTIONS
───────────────────────────────────────────────────────────── */
let currentMember = null;

function showMemberMessage(message, type = 'danger') {
    const msgEl = document.getElementById('memberMessage');
    msgEl.textContent = message;
    msgEl.className = `alert alert-${type} mt-2 mb-0 py-2`;
    msgEl.style.display = 'block';
    setTimeout(() => {
        msgEl.style.display = 'none';
    }, 4000);
}

function searchMember() {
    const phoneNumber = document.getElementById('searchMemberPhone').value.trim();
    
    if (!phoneNumber) {
        showMemberMessage('Vui lòng nhập số điện thoại!', 'warning');
        return;
    }

    const spinner = document.getElementById('memberLoadingSpinner');
    spinner.style.display = 'block';

    const token = document.querySelector('input[name=__RequestVerificationToken]')?.value;

    fetch('?handler=SearchMember', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'RequestVerificationToken': token
        },
        body: JSON.stringify({ phoneNumber: phoneNumber })
    })
    .then(r => r.json())
    .then(data => {
        spinner.style.display = 'none';
        
        if (data.success) {
            currentMember = data.member;
            displayMemberInfo();
            showMemberMessage('Tìm thấy thành viên!', 'success');
        } else {
            showMemberMessage(data.message, 'warning');
        }
    })
    .catch(err => {
        spinner.style.display = 'none';
        showMemberMessage('Lỗi kết nối: ' + err, 'danger');
    });
}

function displayMemberInfo() {
    if (!currentMember) return;

    document.getElementById('memberName').textContent = currentMember.fullName;
    document.getElementById('memberPhone').textContent = `SĐT: ${currentMember.phoneNumber || '-'}`;
    document.getElementById('memberPoints').textContent = `Điểm: ${parseFloat(currentMember.loyaltyPoints).toLocaleString()}`;
    document.getElementById('availablePoints').textContent = parseFloat(currentMember.loyaltyPoints).toLocaleString();
    document.getElementById('memberInfo').style.display = 'block';
    document.getElementById('searchMemberPhone').value = '';
    
    // Cập nhật điểm khả dụng
    currentMemberPoints = parseFloat(currentMember.loyaltyPoints) || 0;
    document.getElementById('loyaltyPointsToUse').max = currentMemberPoints;
}

function clearMember() {
    currentMember = null;
    currentMemberPoints = 0;
    loyaltyPointsToUse = 0;
    document.getElementById('memberInfo').style.display = 'none';
    document.getElementById('loyaltyPointsToUse').value = 0;
    document.getElementById('availablePoints').textContent = '0';
    document.getElementById('searchMemberPhone').value = '';
    renderCart();
}

function openCreateMemberModal() {
    const modal = new bootstrap.Modal(document.getElementById('createMemberModal'), {});
    document.getElementById('createMemberForm').reset();
    document.getElementById('createMemberError').style.display = 'none';
    modal.show();
}

function confirmCreateMember() {
    const fullName = document.getElementById('newMemberName').value.trim();
    const phoneNumber = document.getElementById('newMemberPhone').value.trim();
    const email = document.getElementById('newMemberEmail').value.trim();

    if (!fullName || !phoneNumber) {
        document.getElementById('createMemberError').textContent = 'Vui lòng nhập đầy đủ tên và SĐT!';
        document.getElementById('createMemberError').style.display = 'block';
        return;
    }

    const token = document.querySelector('input[name=__RequestVerificationToken]')?.value;

    fetch('?handler=CreateMember', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'RequestVerificationToken': token
        },
        body: JSON.stringify({ 
            fullName: fullName, 
            phoneNumber: phoneNumber,
            email: email || null
        })
    })
    .then(r => r.json())
    .then(data => {
        if (data.success) {
            currentMember = data.member;
            displayMemberInfo();
            bootstrap.Modal.getInstance(document.getElementById('createMemberModal')).hide();
            showMemberMessage(data.message, 'success');
        } else {
            document.getElementById('createMemberError').textContent = data.message;
            document.getElementById('createMemberError').style.display = 'block';
        }
    })
    .catch(err => {
        document.getElementById('createMemberError').textContent = 'Lỗi kết nối: ' + err;
        document.getElementById('createMemberError').style.display = 'block';
    });
}

/* ─────────────────────────────────────────────────────────────
   CHECKOUT WITH MEMBER
───────────────────────────────────────────────────────────── */
function checkout() {
    if (cart.length === 0) {
        alert('Giỏ hàng chưa có sản phẩm!');
        return;
    }

    let subtotal = 0;
    cart.forEach(item => subtotal += item.unitPrice * item.quantity);
    const totalAmount = Math.max(0, subtotal - loyaltyPointsToUse);

    // Không cộng thêm discount vì không còn mã giảm giá
    const checkoutItems = cart.map(item => ({
        ProductId: item.productId,
        Quantity: item.quantity,
        UnitPrice: item.unitPrice,
        DiscountApplied: 0
    }));

    const payload = {
        MemberCardId: currentMember ? currentMember.memberCardId : null,
        MemberName: currentMember ? currentMember.fullName : null,
        MemberPhoneNumber: currentMember ? currentMember.phoneNumber : null,
        LoyaltyPointsToUse: loyaltyPointsToUse,
        Items: checkoutItems,
        TotalAmount: totalAmount,
        PaymentMethod: 'Cash'
    };

    const token = document.querySelector('input[name=__RequestVerificationToken]')?.value;

    fetch('?handler=Checkout', {
        method: 'POST',
        headers: { 
            'Content-Type': 'application/json',
            'RequestVerificationToken': token
        },
        body: JSON.stringify(payload)
    })
    .then(r => r.json())
    .then(data => {
        if (data.success) {
            let message = data.message;
            if (currentMember) {
                const pointsEarned = Math.round(subtotal * 0.01);
                const pointsNetUsed = loyaltyPointsToUse > 0 ? loyaltyPointsToUse : 0;
                message += `\n\nThành viên ${currentMember.fullName}:`;
                message += `\n- Cộng điểm: +${pointsEarned}`;
                if (pointsNetUsed > 0) {
                    message += `\n- Trừ điểm: -${pointsNetUsed}`;
                }
            }
            alert(message);
            cart = [];
            loyaltyPointsToUse = 0;
            clearMember();
            renderCart();
            window.location.reload();
        } else {
            alert('Thanh toán thất bại: ' + data.message);
        }
    })
    .catch(err => {
        alert('Lỗi kết nối máy chủ: ' + err);
    });
}
</script>
}
