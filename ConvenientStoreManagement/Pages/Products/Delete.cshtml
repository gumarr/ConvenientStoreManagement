@page
@model ConvenientStoreManagement.Pages.Products.DeleteModel

@{
    ViewData["Title"] = "Delete Product";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h2>@ViewData["Title"]</h2>
            <hr />

            <div class="alert alert-warning" role="alert">
                <strong>Are you sure you want to delete this product?</strong> This action cannot be undone.
            </div>

            <div class="card">
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">Product Name</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.Product.ProductName)</dd>

                        <dt class="col-sm-3">Category</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.Product.Category.CategoryName)</dd>

                        <dt class="col-sm-3">Price</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.Product.Price)</dd>

                        <dt class="col-sm-3">Cost Price</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.Product.CostPrice)</dd>

                        <dt class="col-sm-3">Quantity</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.Product.Quantity)</dd>

                        <dt class="col-sm-3">Status</dt>
                        <dd class="col-sm-9">
                            @if (Model.Product.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactive</span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>

            <form method="post" style="display: inline;" class="mt-3">
                <button type="submit" class="btn btn-danger">Confirm Delete</button>
                <a asp-page="Index" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>
