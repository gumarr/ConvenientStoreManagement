@page "{id:int}"
@model ConvenientStoreManagement.Pages.Products.DeleteModel
@{
    ViewData["Title"] = "Delete Product";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card border-danger shadow-sm">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0 text-danger">
                <h3 class="card-title">Delete Product</h3>
            </div>
            <div class="card-body p-4">
                <h5 class="mb-4">Are you sure you want to delete this product?</h5>
                
                <dl class="row">
                    <dt class="col-sm-3">Name</dt>
                    <dd class="col-sm-9">@Model.Product.Name</dd>
                    
                    <dt class="col-sm-3">Price</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(m => m.Product.Price)</dd>
                    
                    <dt class="col-sm-3">Category</dt>
                    <dd class="col-sm-9">@Model.Product.CategoryName</dd>
                    
                    <dt class="col-sm-3">Stock</dt>
                    <dd class="col-sm-9">@Model.Product.Stock</dd>
                </dl>
                
                <form method="post">
                    <input type="hidden" asp-for="Product.ProductId" />
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-danger px-4">Confirm Delete</button>
                        <a asp-page="./Index" class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
