<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Convenient Store Management</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ConvenientStoreManagement.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom navbar-clean">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-area="" asp-page="/Index">
                    <span class="brand-icon">📦</span>
                    <span>Store Manager</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="" asp-page="/Dashboard/Index">Dashboard</a>
                                </li>
                            }
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-page="/Products/Browse">🛒 Bán hàng</a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-dark" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Management
                                </a>
                                <ul class="dropdown-menu shadow-sm border-0" aria-labelledby="navbarDropdown">
                                <li><a class="dropdown-item py-2" asp-area="" asp-page="/Inventory/Import">📦 Import Inventory</a></li>
                                <li><a class="dropdown-item py-2" asp-area="" asp-page="/Inventory/History">📜 Import History</a></li>
                                @if (User.IsInRole("Admin"))
                                {
                                    <li><hr class="dropdown-divider my-1" /></li>
                                    <li><a class="dropdown-item py-2" asp-area="" asp-page="/Users/Index">👥 Users</a></li>
                                }
                                </ul>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav ms-auto align-items-center">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <!-- Avatar dropdown thay cho "Hello, username" -->
                            <li class="nav-item dropdown me-1">
                                <a class="nav-link dropdown-toggle d-flex align-items-center gap-2 text-dark"
                                   href="#" id="userDropdown" role="button"
                                   data-bs-toggle="dropdown" aria-expanded="false">
                                    <span class="navbar-avatar">
                                        @User.Identity.Name!.Substring(0, 1).ToUpper()
                                    </span>
                                    <span class="fw-medium d-none d-md-inline">@User.Identity.Name</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0" aria-labelledby="userDropdown">
                                    <li>
                                        <a class="dropdown-item py-2 d-flex align-items-center gap-2"
                                           asp-page="/Profile/Index">
                                            👤 My Profile
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider my-1" /></li>
                                    <li>
                                        <form asp-page="/Authentication/Logout" method="post" class="d-inline w-100">
                                            <button type="submit" class="dropdown-item py-2 d-flex align-items-center gap-2 text-danger">
                                                🚪 Logout
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm px-4 rounded-pill shadow-sm" asp-area="" asp-page="/Authentication/Login">Login</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @if (ViewData["IsFullWidth"] != null && ViewData["IsFullWidth"] is bool isFullWidth && isFullWidth)
        {
            @RenderBody()
        }
        else
        {
            <div class="container-custom py-4">
                @RenderBody()
            </div>
        }
    </main>

    <footer class="footer-clean bg-light border-top mt-5">
        <div class="container py-4">
            <div class="row">
                <div class="col-md-6">
                    <p class="text-muted mb-0">&copy; 2026 - Convenient Store Management</p>
                </div>
                <div class="col-md-6 text-end">
                    <a asp-area="" asp-page="/Privacy" class="text-muted text-decoration-none">Privacy</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
