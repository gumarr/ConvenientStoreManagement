@page
@model ConvenientStoreManagement.Pages.Users.IndexModel
@{
    ViewData["Title"] = "User Management";
}
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        ✅ @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        ⚠️ @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>User Management</h2>
    <a asp-page="Create" class="btn btn-primary">Create New User</a>
</div>

<form method="get" class="mb-4">
    <div class="row g-3">
        <div class="col-md-5">
            <input type="text" name="search" value="@Model.CurrentSearch" class="form-control"
                   placeholder="Search by username or full name..." />
        </div>
        <div class="col-md-4">
            <select name="role" class="form-select">
                <option value="">All Roles</option>
                <option value="Admin" selected="@(Model.CurrentRole == "Admin")">Admin</option>
                <option value="Staff" selected="@(Model.CurrentRole == "Staff")">Staff</option>
            </select>
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
            <a asp-page="./Index" class="btn btn-outline-secondary">Clear</a>
        </div>
    </div>
</form>

<div class="table-responsive bg-white rounded shadow-sm">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>Username</th>
                <th>Full Name</th>
                <th>Role</th>
                <th>Created At</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model.Users)
            {
                <tr>
                    <td class="fw-medium">@user.Username</td>
                    <td>@user.FullName</td>
                    <td>
                        <span class="badge @(user.Role == "Admin" ? "bg-danger" : "bg-info")">@user.Role</span>
                    </td>
                    <td>@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                    <td class="text-end">
                        <a asp-page="./Edit" asp-route-id="@user.UserId" class="btn btn-sm btn-outline-primary">Edit</a>
                        <a asp-page="./Delete" asp-route-id="@user.UserId" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
            @if (!Model.Users.Any())
            {
                <tr>
                    <td colspan="5" class="text-center py-4 text-muted">No users found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@{
    string? prevDisabled = !Model.Users.HasPreviousPage ? "disabled" : "";
    string? nextDisabled = !Model.Users.HasNextPage ? "disabled" : "";
}

<div class="d-flex justify-content-between align-items-center mt-4">
    <span class="text-muted">Page @Model.Users.PageIndex of @Model.Users.TotalPages</span>
    <div class="btn-group">
        <a asp-page="./Index" asp-route-pageIndex="@(Model.Users.PageIndex - 1)" asp-route-search="@Model.CurrentSearch"
               asp-route-role="@Model.CurrentRole" class="btn btn-outline-primary @prevDisabled">
            Previous
        </a>
        <a asp-page="./Index" asp-route-pageIndex="@(Model.Users.PageIndex + 1)" asp-route-search="@Model.CurrentSearch"
               asp-route-role="@Model.CurrentRole" class="btn btn-outline-primary @nextDisabled">
            Next
        </a>
    </div>
</div>
