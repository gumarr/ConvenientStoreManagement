@page "{id:int}"
@model ConvenientStoreManagement.Pages.Users.DeleteModel
@{
    ViewData["Title"] = "Delete User";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-danger shadow-sm">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0 text-danger">
                <h3 class="card-title">Delete User</h3>
            </div>
            <div class="card-body p-4">
                <h5 class="mb-4">Are you sure you want to delete this user?</h5>
                
                <dl class="row">
                    <dt class="col-sm-4">Username</dt>
                    <dd class="col-sm-8">@Model.UserViewModel.Username</dd>
                    
                    <dt class="col-sm-4">Full Name</dt>
                    <dd class="col-sm-8">@Model.UserViewModel.FullName</dd>
                    
                    <dt class="col-sm-4">Role</dt>
                    <dd class="col-sm-8">@Model.UserViewModel.Role</dd>
                    
                    <dt class="col-sm-4">Created At</dt>
                    <dd class="col-sm-8">@Model.UserViewModel.CreatedAt.ToString("g")</dd>
                </dl>
                
                <form method="post">
                    <input type="hidden" asp-for="UserViewModel.UserId" />
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-danger px-4">Confirm Delete</button>
                        <a asp-page="./Index" class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
