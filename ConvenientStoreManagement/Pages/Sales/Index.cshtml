@page
@model ConvenientStoreManagement.Pages.Sales.IndexModel

@{
    ViewData["Title"] = "Sales";
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col-md-6">
            <h2>@ViewData["Title"]</h2>
        </div>
        <div class="col-md-6 text-end">
            <a asp-page="Create" class="btn btn-primary">+ New Sale</a>
        </div>
    </div>

    @if (Model.Sales.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Sale ID</th>
                        <th>Customer</th>
                        <th>Sale Date</th>
                        <th>Total Amount</th>
                        <th>Paid Amount</th>
                        <th>Discount</th>
                        <th>Payment Method</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var sale in Model.Sales)
                    {
                        <tr>
                            <td>@sale.SaleId</td>
                            <td>@sale.Customer?.CustomerName</td>
                            <td>@sale.SaleDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@sale.TotalAmount.ToString("C")</td>
                            <td>@sale.PaidAmount.ToString("C")</td>
                            <td>@sale.DiscountAmount.ToString("C")</td>
                            <td>@sale.PaymentMethod</td>
                            <td>
                                @if (sale.IsCompleted)
                                {
                                    <span class="badge bg-success">Completed</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning">Pending</span>
                                }
                            </td>
                            <td>
                                <a asp-page="Edit" asp-route-id="@sale.SaleId" class="btn btn-sm btn-warning">Edit</a>
                                <a asp-page="Delete" asp-route-id="@sale.SaleId" class="btn btn-sm btn-danger">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">No sales found. <a asp-page="Create">Create one now</a></div>
    }
</div>
