@page
@model ConvenientStoreManagement.Pages.Sales.DeleteModel

@{
    ViewData["Title"] = "Delete Sale";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h2>@ViewData["Title"]</h2>
            <hr />

            <div class="alert alert-warning" role="alert">
                <strong>Are you sure you want to delete this sale?</strong> This action cannot be undone.
            </div>

            <div class="card">
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">Sale ID</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.Sale.SaleId)</dd>

                        <dt class="col-sm-3">Customer</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.Sale.Customer.CustomerName)</dd>

                        <dt class="col-sm-3">Sale Date</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.Sale.SaleDate)</dd>

                        <dt class="col-sm-3">Total Amount</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.Sale.TotalAmount)</dd>

                        <dt class="col-sm-3">Paid Amount</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.Sale.PaidAmount)</dd>

                        <dt class="col-sm-3">Discount</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.Sale.DiscountAmount)</dd>

                        <dt class="col-sm-3">Payment Method</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.Sale.PaymentMethod)</dd>

                        <dt class="col-sm-3">Status</dt>
                        <dd class="col-sm-9">
                            @if (Model.Sale.IsCompleted)
                            {
                                <span class="badge bg-success">Completed</span>
                            }
                            else
                            {
                                <span class="badge bg-warning">Pending</span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>

            <form method="post" style="display: inline;" class="mt-3">
                <button type="submit" class="btn btn-danger">Confirm Delete</button>
                <a asp-page="Index" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>
