@page
@model ConvenientStoreManagement.Pages.Sales.CreateModel

@{
  ViewData["Title"] = "Create Sale";
}

<div class="container mt-4">
  <div class="row">
    <div class="col-md-8 offset-md-2">
      <h2>@ViewData["Title"]</h2>
      <hr />

      @if (!Model.CustomerList.Any())
      {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
          <strong>⚠️ Cannot create sale!</strong> You need to create at least one customer first.
          <a asp-page="/Customers/Create" class="btn btn-sm btn-primary ms-2">Create Customer</a>
        </div>
      }

      @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Any())
      {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
          <strong>❌ Validation Error!</strong> Please fix the following:
          <ul class="mb-0 mt-2">
            @foreach (var entry in ViewData.ModelState)
            {
              @foreach (var error in entry.Value.Errors)
              {
                <li>@error.ErrorMessage</li>
              }
            }
          </ul>
        </div>
      }

      <form method="post">
        <div class="mb-3">
          <label asp-for="Sale.CustomerId" class="form-label">Customer <span class="text-danger">*</span></label>
          <select asp-for="Sale.CustomerId" asp-items="Model.CustomerList" class="form-control" required>
            <option value="">-- Select Customer --</option>
          </select>
          <span asp-validation-for="Sale.CustomerId" class="text-danger"></span>
        </div>

        <div class="row">
          <div class="col-md-6 mb-3">
            <label asp-for="Sale.TotalAmount" class="form-label">Total Amount <span class="text-danger">*</span></label>
            <input asp-for="Sale.TotalAmount" class="form-control" step="0.01" required />
            <span asp-validation-for="Sale.TotalAmount" class="text-danger"></span>
          </div>
          <div class="col-md-6 mb-3">
            <label asp-for="Sale.PaidAmount" class="form-label">Paid Amount <span class="text-danger">*</span></label>
            <input asp-for="Sale.PaidAmount" class="form-control" step="0.01" required />
            <span asp-validation-for="Sale.PaidAmount" class="text-danger"></span>
          </div>
        </div>

        <div class="row">
          <div class="col-md-6 mb-3">
            <label asp-for="Sale.DiscountAmount" class="form-label">Discount Amount</label>
            <input asp-for="Sale.DiscountAmount" class="form-control" step="0.01" value="0" />
          </div>
          <div class="col-md-6 mb-3">
            <label asp-for="Sale.PaymentMethod" class="form-label">Payment Method</label>
            <input asp-for="Sale.PaymentMethod" class="form-control" placeholder="Cash, Card, Transfer..." />
          </div>
        </div>

        <div class="mb-3">
          <label asp-for="Sale.Notes" class="form-label">Notes</label>
          <textarea asp-for="Sale.Notes" class="form-control" rows="3"></textarea>
        </div>

        <div class="mb-3 form-check">
          <input asp-for="Sale.IsCompleted" class="form-check-input" id="isCompleted" />
          <label asp-for="Sale.IsCompleted" class="form-check-label" for="isCompleted">Completed</label>
        </div>

        <div class="mb-3">
          <button type="submit" class="btn btn-primary">Create
            Sale</button>
            <a asp-page="Index" class="btn btn-secondary">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>

  @section Scripts {
    @{
      await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
  }
