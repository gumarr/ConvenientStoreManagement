@page
@model ConvenientStoreManagement.Pages.Customers.CreateModel

@{
    ViewData["Title"] = "Create Customer";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h2>@ViewData["Title"]</h2>
            <hr />

            <form method="post">
                <div class="mb-3">
                    <label asp-for="Customer.CustomerName" class="form-label">Customer Name</label>
                    <input asp-for="Customer.CustomerName" class="form-control" />
                    <span asp-validation-for="Customer.CustomerName" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Customer.PhoneNumber" class="form-label">Phone Number</label>
                        <input asp-for="Customer.PhoneNumber" class="form-control" />
                        <span asp-validation-for="Customer.PhoneNumber" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Customer.Email" class="form-label">Email</label>
                        <input asp-for="Customer.Email" class="form-control" type="email" />
                        <span asp-validation-for="Customer.Email" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Customer.Address" class="form-label">Address</label>
                    <textarea asp-for="Customer.Address" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Customer.Address" class="text-danger"></span>
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="Customer.IsActive" class="form-check-input" />
                    <label asp-for="Customer.IsActive" class="form-check-label">Active</label>
                </div>

                <div class="mb-3">
                    <button type="submit" class="btn btn-primary">Create</button>
                    <a asp-page="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
