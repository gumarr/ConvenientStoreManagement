@page
@model ConvenientStoreManagement.Pages.Customers.DeleteModel

@{
    ViewData["Title"] = "Delete Customer";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h2>@ViewData["Title"]</h2>
            <hr />

            <div class="alert alert-warning" role="alert">
                <strong>Are you sure you want to delete this customer?</strong> This action cannot be undone.
            </div>

            <div class="card">
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">Customer Name</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.Customer.CustomerName)</dd>

                        <dt class="col-sm-3">Phone Number</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.Customer.PhoneNumber)</dd>

                        <dt class="col-sm-3">Email</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.Customer.Email)</dd>

                        <dt class="col-sm-3">Address</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.Customer.Address)</dd>

                        <dt class="col-sm-3">Status</dt>
                        <dd class="col-sm-9">
                            @if (Model.Customer.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactive</span>
                            }
                        </dd>

                        <dt class="col-sm-3">Created Date</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.Customer.CreatedDate)</dd>
                    </dl>
                </div>
            </div>

            <form method="post" style="display: inline;" class="mt-3">
                <button type="submit" class="btn btn-danger">Confirm Delete</button>
                <a asp-page="Index" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>
