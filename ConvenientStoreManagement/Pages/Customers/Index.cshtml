@page
@model ConvenientStoreManagement.Pages.Customers.IndexModel

@{
    ViewData["Title"] = "Customers";
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col-md-6">
            <h2>@ViewData["Title"]</h2>
        </div>
        <div class="col-md-6 text-end">
            <a asp-page="Create" class="btn btn-primary">+ New Customer</a>
        </div>
    </div>

    @if (Model.Customers.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Customer Name</th>
                        <th>Phone</th>
                        <th>Email</th>
                        <th>Address</th>
                        <th>Status</th>
                        <th>Created Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var customer in Model.Customers)
                    {
                        <tr>
                            <td>@customer.CustomerName</td>
                            <td>@customer.PhoneNumber</td>
                            <td>@customer.Email</td>
                            <td>@customer.Address</td>
                            <td>
                                @if (customer.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inactive</span>
                                }
                            </td>
                            <td>@customer.CreatedDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <a asp-page="Edit" asp-route-id="@customer.CustomerId" class="btn btn-sm btn-warning">Edit</a>
                                <a asp-page="Delete" asp-route-id="@customer.CustomerId" class="btn btn-sm btn-danger">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">No customers found. <a asp-page="Create">Create one now</a></div>
    }
</div>
