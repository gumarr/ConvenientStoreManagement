@page
@model ConvenientStoreManagement.Pages.Dashboard.IndexModel
@{
    ViewData[index: "Title"] = "Revenue & Profit Statistics";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Revenue & Profit Statistics</h2>
</div>

<!-- ================= SUMMARY ================= -->
<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card bg-primary text-white shadow-sm border-0">
            <div class="card-body">
                <h6>Today Revenue</h6>
                <h3>@Model.Stats.TodayRevenue.ToString(format: "N0") ₫</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card bg-success text-white shadow-sm border-0">
            <div class="card-body">
                <h6>Today Profit</h6>
                <h3>@Model.Stats.TodayProfit.ToString(format: "N0") ₫</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card bg-info text-white shadow-sm border-0">
            <div class="card-body">
                <h6>This Week Revenue</h6>
                <h3>@Model.Stats.ThisWeekRevenue.ToString(format: "N0") ₫</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card bg-warning shadow-sm border-0">
            <div class="card-body">
                <h6>This Month Revenue</h6>
                <h3>@Model.Stats.ThisMonthRevenue.ToString(format: "N0") ₫</h3>
            </div>
        </div>
    </div>
</div>

<!-- ================= CHART + TOP ================= -->
<div class="row g-4 mb-4">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-header">Revenue & Profit (30 days)</div>
            <div class="card-body">
                <canvas id="revenueChart"></canvas>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card shadow-sm border-0">
            <div class="card-header">Top 5 Products</div>
            <div class="card-body">
                @foreach (ViewModels.TopProductDto p in Model.Stats.TopProducts)
                {
                    <div class="d-flex justify-content-between">
                        <span>@p.ProductName</span>
                        <b>@p.TotalQuantitySold</b>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- ================= LOW STOCK ================= -->
@if (Model.Stats.LowStockProductCount > 0)
{
    <div class="card border-danger border-2 mb-4">
        <div class="card-header text-danger">⚠️ Low Stock</div>
        <div class="card-body">
            @foreach (ViewModels.LowStockProductDto p in Model.Stats.LowStockProducts)
            {
                <div class="d-flex justify-content-between">
                    <span>@p.ProductName</span>
                    <b class="text-danger">@p.CurrentStock</b>
                </div>
            }
        </div>
    </div>
}

<!-- ================= AI ================= -->
<form method="post" asp-page-handler="AISuggest">
    <button class="btn btn-dark mb-3">🤖 AI Suggest</button>
</form>

@if (!string.IsNullOrEmpty(Model.AIResult))
{
    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
            AI Suggestion
        </div>
        <div class="card-body">
            @Html.Raw(Model.AIResult.Replace(oldValue: "\n", newValue: "<br/>"))
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Stats.ChartLabels));
        const revenue = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Stats.ChartRevenue));
        const profit = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Stats.ChartProfit));

        const ctx = document.getElementById('revenueChart');

        new Chart(ctx, {
        type: 'line',
        data: {
        labels: labels,
        datasets: [
        {
        label: 'Revenue',
        data: revenue,
        borderColor: '#0d6efd'
        },
        {
        label: 'Profit',
        data: profit,
        borderColor: '#198754'
        }
        ]
        }
        });
    </script>
}
