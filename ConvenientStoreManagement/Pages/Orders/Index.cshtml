@page
@model ConvenientStoreManagement.Pages.Orders.IndexModel
@{
    ViewData["Title"] = "Order Management";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Order History</h2>
</div>

<form method="get" class="mb-4">
    <div class="row g-3">
        <div class="col-md-3">
            <label class="form-label small text-muted mb-1">Start Date</label>
            <input type="date" name="startDate" value="@Model.CurrentStartDate?.ToString("yyyy-MM-dd")" class="form-control" />
        </div>
        <div class="col-md-3">
            <label class="form-label small text-muted mb-1">End Date</label>
            <input type="date" name="endDate" value="@Model.CurrentEndDate?.ToString("yyyy-MM-dd")" class="form-control" />
        </div>
        <div class="col-md-3">
            <label class="form-label small text-muted mb-1">Status</label>
            <select name="status" class="form-select">
                <option value="">All Statuses</option>
                <option value="Completed" selected="@(Model.CurrentStatus == "Completed")">Completed</option>
                <option value="Pending" selected="@(Model.CurrentStatus == "Pending")">Pending</option>
                <option value="Cancelled" selected="@(Model.CurrentStatus == "Cancelled")">Cancelled</option>
            </select>
        </div>
        <div class="col-md-3 d-flex align-items-end gap-2">
            <button type="submit" class="btn btn-outline-primary w-100">Filter</button>
            <a asp-page="./Index" class="btn btn-outline-secondary">Clear</a>
        </div>
    </div>
</form>

<div class="table-responsive bg-white rounded shadow-sm">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>Order ID</th>
                <th>Customer</th>
                <th>Date</th>
                <th>Total Amount</th>
                <th>Status</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model.Orders)
            {
                <tr>
                    <td class="fw-bold text-muted">#@order.OrderId</td>
                    <td>@order.CustomerName</td>
                    <td>@order.CreatedAt.ToString("MMM dd, yyyy HH:mm")</td>
                    <td class="fw-medium">@Html.DisplayFor(m => order.TotalAmount)</td>
                    <td>
                        @{
                            var badgeClass = order.Status switch
                            {
                                "Completed" => "bg-success",
                                "Pending" => "bg-warning",
                                "Cancelled" => "bg-danger",
                                _ => "bg-secondary"
                            };
                        }
                        <span class="badge @badgeClass">@order.Status</span>
                    </td>
                    <td class="text-end">
                        <a asp-page="./Details" asp-route-id="@order.OrderId" class="btn btn-sm btn-outline-info">View Details</a>
                    </td>
                </tr>
            }
            @if (!Model.Orders.Any())
            {
                <tr>
                    <td colspan="6" class="text-center py-4 text-muted">No orders found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@{
    var prevDisabled = !Model.Orders.HasPreviousPage ? "disabled" : "";
    var nextDisabled = !Model.Orders.HasNextPage ? "disabled" : "";
}

<div class="d-flex justify-content-between align-items-center mt-4">
    <span class="text-muted">Page @Model.Orders.PageIndex of @Model.Orders.TotalPages</span>
    <div class="btn-group">
        <a asp-page="./Index"
           asp-route-pageIndex="@(Model.Orders.PageIndex - 1)"
           asp-route-startDate="@Model.CurrentStartDate?.ToString("yyyy-MM-dd")"
           asp-route-endDate="@Model.CurrentEndDate?.ToString("yyyy-MM-dd")"
           asp-route-status="@Model.CurrentStatus"
           class="btn btn-outline-primary @prevDisabled">
            Previous
        </a>
        <a asp-page="./Index"
           asp-route-pageIndex="@(Model.Orders.PageIndex + 1)"
           asp-route-startDate="@Model.CurrentStartDate?.ToString("yyyy-MM-dd")"
           asp-route-endDate="@Model.CurrentEndDate?.ToString("yyyy-MM-dd")"
           asp-route-status="@Model.CurrentStatus"
           class="btn btn-outline-primary @nextDisabled">
            Next
        </a>
    </div>
</div>
