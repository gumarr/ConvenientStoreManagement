@page "{id:int}"
@model ConvenientStoreManagement.Pages.Orders.DetailsModel
@{
    ViewData["Title"] = "Order Details";
}

<div class="container-fluid">
    <div class="row mb-3">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <h2>Order Details #@Model.Order.OrderId</h2>
            <a asp-page="./History" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to History
            </a>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Order Information</h5>
                </div>
                <div class="card-body">
                    <table class="table table-borderless table-sm mb-0">
                        <tbody>
                            <tr>
                                <th style="width: 30%">Order ID:</th>
                                <td>#@Model.Order.OrderId</td>
                            </tr>
                            <tr>
                                <th>Date:</th>
                                <td>@Model.Order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                            </tr>
                            <tr>
                                <th>Staff/User:</th>
                                <td>@(Model.Order.User?.Username ?? "Unknown")</td>
                            </tr>
                            <tr>
                                <th>Status:</th>
                                <td><span class="badge bg-success">Completed</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card shadow-sm h-100 bg-primary text-white">
                <div class="card-body d-flex flex-column justify-content-center align-items-center">
                    <h5 class="mb-2">Total Amount</h5>
                    <h2 class="mb-0 fw-bold">@Model.Order.TotalAmount.ToString("N0") ₫</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <h5 class="mb-0">Order Items</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Product Name</th>
                            <th class="text-end">Import Cost<br><small class="text-muted">(Snapshot)</small></th>
                            <th class="text-end">Unit Price</th>
                            <th class="text-center">Quantity</th>
                            <th class="text-end">Discount</th>
                            <th class="text-end">Line Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var detail in Model.Order.OrderDetails)
                        {
                            var lineTotal = (detail.UnitPrice * detail.Quantity) - detail.DiscountApplied;
                            <tr>
                                <td>@(detail.Product?.Name ?? "Unknown Product")</td>
                                <td class="text-end text-muted">@detail.ImportCostSnapshot.ToString("N0") ₫</td>
                                <td class="text-end">@detail.UnitPrice.ToString("N0") ₫</td>
                                <td class="text-center">@detail.Quantity</td>
                                <td class="text-end text-danger">@((detail.DiscountApplied > 0) ? "-" + detail.DiscountApplied.ToString("N0") + " ₫" : "0 ₫")</td>
                                <td class="text-end fw-bold">@lineTotal.ToString("N0") ₫</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td colspan="5" class="text-end fw-bold">Subtotal:</td>
                            <td class="text-end fw-bold">@Model.Order.OrderDetails.Sum(d => (d.UnitPrice * d.Quantity)).ToString("N0") ₫</td>
                        </tr>
                        @if (Model.Order.OrderDetails.Sum(d => d.DiscountApplied) > 0)
                        {
                            <tr>
                                <td colspan="5" class="text-end fw-bold text-danger">Total Discount:</td>
                                <td class="text-end fw-bold text-danger">-@Model.Order.OrderDetails.Sum(d => d.DiscountApplied).ToString("N0") ₫</td>
                            </tr>
                        }
                        <tr class="table-primary">
                            <td colspan="5" class="text-end fw-bold text-white">Final Total:</td>
                            <td class="text-end fw-bold text-white">@Model.Order.TotalAmount.ToString("N0") ₫</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>
