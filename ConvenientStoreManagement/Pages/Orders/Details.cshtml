@page "{id:int}"
@model ConvenientStoreManagement.Pages.Orders.DetailsModel
@{
    ViewData["Title"] = "Order Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Order #@Model.Order?.OrderId Details</h2>
    <div>
        <a asp-page="./Index" class="btn btn-outline-secondary">Back to List</a>
    </div>
</div>

@if (Model.Order == null)
{
    <div class="alert alert-danger">Order not found.</div>
}
else
{
    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                    <h5 class="card-title text-muted mb-0">Summary</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-5 text-muted fw-normal">Customer</dt>
                        <dd class="col-sm-7 fw-medium">@Model.Order.User?.FullName</dd>

                        <dt class="col-sm-5 text-muted fw-normal">Date</dt>
                        <dd class="col-sm-7">@Model.Order.CreatedAt.ToString("MMM dd, yyyy HH:mm")</dd>

                        <dt class="col-sm-5 text-muted fw-normal">Status</dt>
                        <dd class="col-sm-7">
                            <span class="badge @(Model.Order.Status == "Completed" ? "bg-success" : (Model.Order.Status == "Pending" ? "bg-warning" : "bg-danger"))">
                                @Model.Order.Status
                            </span>
                        </dd>

                        <dt class="col-sm-5 text-muted fw-normal">Total Amount</dt>
                        <dd class="col-sm-7 fw-bold text-primary fs-5">@Model.Order.TotalAmount.ToString("C0")</dd>
                    </dl>
                    
                    @if (Model.Order.Status == "Pending")
                    {
                        <hr class="my-4" />
                        <form method="post" asp-page-handler="UpdateStatus">
                            <input type="hidden" name="orderId" value="@Model.Order.OrderId" />
                            <div class="d-flex gap-2">
                                <button type="submit" name="status" value="Completed" class="btn btn-success btn-sm w-100">Mark Completed</button>
                                <button type="submit" name="status" value="Cancelled" class="btn btn-outline-danger btn-sm w-100">Cancel Order</button>
                            </div>
                        </form>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-8 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                    <h5 class="card-title text-muted mb-0">Order Items</h5>
                </div>
                <div class="card-body p-0 mt-3">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Product</th>
                                    <th class="text-center">Price</th>
                                    <th class="text-center">Qty</th>
                                    <th class="text-center">Discount</th>
                                    <th class="text-end pe-4">Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.OrderItems)
                                {
                                    <tr>
                                        <td class="ps-4 fw-medium">@item.ProductName</td>
                                        <td class="text-center">@item.UnitPrice.ToString("C0")</td>
                                        <td class="text-center">@item.Quantity</td>
                                        <td class="text-center">@(item.DiscountPercent)%</td>
                                        <td class="text-end pe-4 fw-medium">@item.Total.ToString("C0")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
